# LLM Configuration — Using Ollama (local)
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_BASE_URL=http://localhost:11434

# Migration Processing Settings
MIGRATION_LOG_LEVEL=INFO
MIGRATION_DLQ_DIR=dlq

# Legacy Database
